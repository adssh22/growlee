# Copier vers .env.prod sur le VPS puis remplacer les valeurs.
# NE PAS commiter .env.prod.

POSTGRES_DB=growlee
POSTGRES_USER=growlee
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_DB_PASSWORD

# Cache partagé production: requis pour un rate-limit fiable avec plusieurs workers Gunicorn.
# Redis reste interne au réseau Docker et n’est pas exposé publiquement.
REDIS_URL=redis://redis:6379/1

DJANGO_DEBUG=0
DJANGO_SECRET_KEY=CHANGE_ME_GENERATE_WITH_DJANGO
DJANGO_ALLOWED_HOSTS=growlee.fr,www.growlee.fr
DJANGO_CSRF_TRUSTED_ORIGINS=https://growlee.fr,https://www.growlee.fr
APP_BASE_URL=https://growlee.fr

# HTTPS / sécurité
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
# Active seulement quand le site est stable en HTTPS et que tous les sous-domaines sont prêts.
DJANGO_SECURE_HSTS_PRELOAD=0

# Caddy / Let's Encrypt
LETSENCRYPT_EMAIL=admin@growlee.fr

# Gunicorn
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60

# Email transactionnel
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=Growlee <noreply@growlee.fr>
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
EMAIL_USE_SSL=0

# SMS transactionnel — valeurs possibles: console, twilio, brevo
SMS_PROVIDER=console
SMS_FROM=Growlee
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
BREVO_API_KEY=
BREVO_SMS_SENDER=Growlee

# Paiement
GROWLEE_PAYMENT_LINK_STARTER=
GROWLEE_PAYMENT_LINK_PRO=
GROWLEE_PAYMENT_LINK_PREMIUM=

# Wallet Apple / Google
APPLE_WALLET_PASS_TYPE_ID=
APPLE_WALLET_TEAM_ID=
APPLE_WALLET_CERT_PATH=
APPLE_WALLET_KEY_PATH=
APPLE_WALLET_WWDR_CERT_PATH=
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SERVICE_ACCOUNT_PATH=
