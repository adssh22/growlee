DATABASE_URL=postgresql+psycopg://growlee:growlee@db:5432/growlee
APP_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Email transactionnel
# Dev: console. Prod exemples: django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=Growlee <noreply@growlee.local>
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1

# SMS transactionnel
# Valeurs: console, twilio, brevo
SMS_PROVIDER=console
SMS_FROM=Growlee
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
BREVO_API_KEY=
BREVO_SMS_SENDER=Growlee

# Wallet Apple / Google — comptes/licences externes à créer côté Apple/Google
