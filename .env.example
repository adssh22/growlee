POSTGRES_DB=growlee
POSTGRES_USER=growlee
POSTGRES_PASSWORD=growlee
DATABASE_URL=postgresql://growlee:growlee@db:5432/growlee
APP_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Médias uploadés: local par défaut. Mettre s3 pour S3 compatible.
DJANGO_MEDIA_STORAGE=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=
AWS_S3_CUSTOM_DOMAIN=

# Téléphones / anti-abus jeu
GROWLEE_DEFAULT_PHONE_REGION=FR
# 0 désactive le cooldown en dev/démo
GROWLEE_PLAY_COOLDOWN_HOURS=24

# Stripe billing — optionnel en dev
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_SUCCESS_URL=http://localhost:8000/admin/?checkout=stripe_success
STRIPE_CANCEL_URL=http://localhost:8000/admin/checkout/?checkout=stripe_cancel

# Email transactionnel
# Dev: console. Prod exemples: django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=Growlee <noreply@growlee.local>
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1

# SMS transactionnel
# Valeurs: console, twilio, brevo
SMS_PROVIDER=console
SMS_FROM=Growlee
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
BREVO_API_KEY=
BREVO_SMS_SENDER=Growlee

# Wallet Apple / Google — comptes/licences externes à créer côté Apple/Google
APPLE_WALLET_PASS_TYPE_ID=
APPLE_WALLET_TEAM_ID=
APPLE_WALLET_CERT_PATH=
APPLE_WALLET_KEY_PATH=
APPLE_WALLET_WWDR_CERT_PATH=
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SERVICE_ACCOUNT_PATH=
